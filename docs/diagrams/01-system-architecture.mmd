%% Crucible — DEPLOYED architecture (as of 2026-06-28).
%% Solid = built & live.  Dotted = planned / optional upgrade.
flowchart TB
    subgraph Client["Frontend — React + TS + Vite (SPA)"]
        UI[Interview UI / Setup / Results]
        VOICE[Browser voice: Web Speech STT + TTS]
        AVA[Stylized interviewer avatar]
    end

    subgraph CDN["AWS edge — HTTPS"]
        CF[CloudFront distribution]
        S3F[S3 — static site bucket]
    end

    subgraph API["Public API"]
        APIGW[API Gateway — HTTP API]
    end

    subgraph Compute["AWS Lambda — FastAPI via Mangum (python3.12)"]
        ROUTES[REST routes: start / turn / finalize / memory]
        subgraph Graph["LangGraph — 5-agent pipeline"]
            IN[Intake Agent]
            PL[Planner Agent]
            IV[Interviewer Agent]
            EV[Evaluator Agent]
            MEM[Memory Agent]
        end
    end

    subgraph AI["Reasoning — Amazon Bedrock (us-west-2)"]
        HAIKU[Claude Haiku 4.5 — intake + memory]
        SONNET[Claude Sonnet 4.6 — planner + interviewer + evaluator]
    end

    subgraph Data["Persistence"]
        DDB[(DynamoDB — crucible-memory)]
        LSTORE[Browser localStorage — active session autosave]
    end

    subgraph Guards["Cost + safety"]
        BUDGET[AWS Budget alert — $10/mo]
        CONC[Lambda concurrency cap — account limit 10]
    end

    %% planned / optional
    PROV[Premium voice/avatar: Deepgram · ElevenLabs · Tavus/D-ID]
    AUTH[Auth: Cognito]

    UI --> CF
    CF --> S3F
    UI -->|fetch /api| APIGW
    APIGW --> ROUTES
    ROUTES --> IN
    IN --> PL
    PL -. reads .-> MEM
    IV --> EV
    EV --> MEM
    IN --> HAIKU
    MEM --> HAIKU
    PL --> SONNET
    IV --> SONNET
    EV --> SONNET
    MEM --> DDB
    ROUTES --> DDB
    UI --> LSTORE
    VOICE -. upgrade .-> PROV
    AVA -. upgrade .-> PROV
    UI -. planned .-> AUTH
